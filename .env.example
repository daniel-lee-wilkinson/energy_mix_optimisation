# Example environment variables file
# Create a copy of this file named ".env" with your actual coordinates and names.
# Ensure your actual .env file is listed in .gitignore and NOT committed.

# Primary Location (e.g., the main remote site for analysis)
PRIMARY_LOCATION_NAME="Example Primary Site"
PRIMARY_LATITUDE="-XX.XXXX"  # Replace with actual latitude
PRIMARY_LONGITUDE="XXX.XXXX" # Replace with actual longitude

# Fallback Location (e.g., an alternative remote site if primary fails)
FALLBACK_LOCATION_NAME="Example Fallback Site"
FALLBACK_LATITUDE="-YY.YYYY"  # Replace with actual latitude
FALLBACK_LONGITUDE="YYY.YYYY" # Replace with actual longitude 

# Optional: analysis period overrides (YYYY-MM-DD)
# Full runs (run_optimization.py and demand sensitivity):
# ANALYSIS_START_DATE="2023-01-01"
# ANALYSIS_END_DATE="2023-12-31"
# Quick test mode (if quick_test=True is used programmatically):
# QUICK_TEST_START_DATE="2023-01-01"
# QUICK_TEST_END_DATE="2023-01-07"

# Optional: capacity search overrides (MW)
# Leave blank to use dynamic bounds derived from data and land constraints.
# PV_CAPACITY_MIN_MW="0"
# PV_CAPACITY_MAX_MW="800"
# WIND_CAPACITY_MIN_MW="0"
# WIND_CAPACITY_MAX_MW="400"
# CAPACITY_STEPS="40"

# Optional: annual atmospheric CO2 removal credit for net GWP reporting
# ANNUAL_CO2_REMOVAL_TONNES="5000"